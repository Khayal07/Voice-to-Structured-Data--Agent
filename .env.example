# OpenAI — used for both Whisper transcription and gpt-4o extraction/generation
OPENAI_API_KEY=sk-your-key-here

# Model selection
# Extraction + eval judge (accuracy-critical) use the stronger model.
OPENAI_EXTRACTION_MODEL=gpt-4o
# Generators (CRM / tasks / email) just format structured data — cheaper model is fine.
OPENAI_GENERATION_MODEL=gpt-4o-mini
OPENAI_TRANSCRIBE_MODEL=whisper-1

# OpenAI request reliability
OPENAI_TIMEOUT_SECONDS=60
OPENAI_MAX_RETRIES=2

# Postgres connection (async driver). Host is "db" inside docker-compose.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/voice_agent

# Ops
LOG_LEVEL=INFO
# Comma-separated allowed CORS origins; "*" allows all (tighten in production).
CORS_ALLOW_ORIGINS=*
MAX_TRANSCRIPT_CHARS=100000
MAX_AUDIO_BYTES=26214400
